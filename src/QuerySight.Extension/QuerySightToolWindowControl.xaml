<UserControl x:Class="QuerySight.Extension.QuerySightToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Background="#18181B" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="False">
                <Button x:Name="btnToggleSql" Content="📝 SQL Query Panel" Click="BtnToggleSql_Click" 
                        Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Padding="8,4" Margin="0,0,8,0" Cursor="Hand"/>
                
                <TextBlock Text="Chart:" VerticalAlignment="Center" Foreground="#A1A1AA" Margin="0,0,4,0"/>
                <ComboBox x:Name="comboChartType" Width="90" SelectedIndex="0" Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Padding="4" Margin="0,0,8,0">
                    <ComboBoxItem Content="bar"/>
                    <ComboBoxItem Content="line"/>
                    <ComboBoxItem Content="pie"/>
                </ComboBox>

                <Button x:Name="btnRunChart" Content="⚡ Run &amp; Chart" Click="BtnRunChart_Click" 
                        Background="#7C3AED" Foreground="White" BorderThickness="0" Padding="12,4" Cursor="Hand" FontWeight="SemiBold"/>

                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#10B981" FontSize="11" TextWrapping="Wrap" MaxWidth="300"/>
            </DockPanel>
        </Border>

        <!-- Collapsible SQL Input Panel -->
        <Border x:Name="sqlPanel" Grid.Row="1" Background="#09090B" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="8" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Panel Header with Toggle Buttons & Connection Info -->
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
                    <TextBlock x:Name="txtConnectionInfo" Text="Connection: Retrieving..." Foreground="#38BDF8" FontSize="11" FontWeight="SemiBold" DockPanel.Dock="Right" VerticalAlignment="Center" TextAlignment="Right"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnSqlMode" Content="SQL Editor" Click="BtnSqlMode_Click" Width="90" Height="22" FontSize="11"
                                Background="#27272A" Foreground="#E4E4E7" BorderBrush="#7C3AED" BorderThickness="1" Cursor="Hand" Margin="0,0,4,0"/>
                        <Button x:Name="btnBuilderMode" Content="Quick Builder" Click="BtnBuilderMode_Click" Width="90" Height="22" FontSize="11"
                                Background="Transparent" Foreground="#A1A1AA" BorderBrush="Transparent" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>

                <!-- SQL Editor View -->
                <Grid x:Name="panelSqlEditor" Grid.Row="1" Visibility="Visible">
                    <TextBox x:Name="txtSqlScript" Height="85" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A" CaretBrush="White" FontFamily="Consolas" FontSize="12" Padding="6"/>
                </Grid>

                <!-- Quick Builder View -->
                <Grid x:Name="panelQuickBuilder" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Table Selection -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,6">
                        <TextBlock Text="Table / View:" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <DockPanel>
                            <Button x:Name="btnRefreshSchema" Content="🔄" Click="BtnRefreshSchema_Click" Width="22" Height="22" Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Cursor="Hand" DockPanel.Dock="Right" ToolTip="Refresh active database tables"/>
                            <ComboBox x:Name="comboTables" Height="22" SelectionChanged="ComboTables_SelectionChanged" Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A" Padding="4"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Aggregation -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,6,6">
                        <TextBlock Text="Aggregation:" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboAggregation" Height="22" SelectedIndex="0" SelectionChanged="ComboAggregation_SelectionChanged" Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A" Padding="4">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="SUM"/>
                            <ComboBoxItem Content="AVG"/>
                            <ComboBoxItem Content="COUNT"/>
                            <ComboBoxItem Content="MIN"/>
                            <ComboBoxItem Content="MAX"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- X-Axis Column -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,6,6">
                        <TextBlock Text="Category (X-Axis):" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboXAxis" Height="22" Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A" Padding="4"/>
                    </StackPanel>

                    <!-- Y-Axis Column -->
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,6">
                        <TextBlock Text="Value (Y-Axis):" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboYAxis" Height="22" Background="#18181B" Foreground="#F4F4F5" BorderBrush="#27272A" Padding="4"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" x:Name="txtBuilderInfo" Text="Select a table to begin mapping columns." Foreground="#71717A" FontSize="10" FontWeight="Normal" Margin="0,2,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Charting View -->
        <Grid Grid.Row="2">
            <wv2:WebView2 x:Name="webView" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Visibility="Collapsed" />
            
            <Grid x:Name="loadingPanel" Background="#121212">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="200" 
                                 Height="6" 
                                 Foreground="#A855F7" 
                                 Background="#1F2937" 
                                 BorderThickness="0" />
                    <TextBlock Text="Initializing QuerySight Canvas..." 
                               Foreground="#9CA3AF" 
                               FontSize="13" 
                               Margin="0,15,0,0" 
                               HorizontalAlignment="Center" 
                               FontFamily="Segoe UI, Arial" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
