<UserControl x:Class="QuerySight.Extension.QuerySightToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#1E1E1E">
    <Grid>
        <!-- The WebView2 control that loads the charting web page -->
        <wv2:WebView2 x:Name="webView" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      Visibility="Collapsed" />
        
        <!-- Loading state panel during WebView2/Extension startup -->
        <Grid x:Name="loadingPanel" Background="#121212">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="6" 
                             Foreground="#A855F7" 
                             Background="#1F2937" 
                             BorderThickness="0" />
                <TextBlock Text="Initializing QuerySight Canvas..." 
                           Foreground="#9CA3AF" 
                           FontSize="13" 
                           Margin="0,15,0,0" 
                           HorizontalAlignment="Center" 
                           FontFamily="Segoe UI, Arial" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
