<UserControl x:Class="QuerySight.Extension.QuerySightToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#1E1E1E">
    <UserControl.Resources>
        <!-- Dark Premium Style for ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Foreground" Value="#E4E4E7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border"
                                Padding="8,4"
                                Background="Transparent"
                                CornerRadius="2"
                                Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#7C3AED" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#4C1D95" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Premium Style for ComboBox -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Foreground" Value="#E4E4E7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          ClickMode="Press" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Name="Border" 
                                                Background="#1E1E1F" 
                                                BorderBrush="#3F3F46" 
                                                BorderThickness="1" 
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" BorderBrush="#3F3F46" BorderThickness="1,0,0,0" Margin="0,2"/>
                                                <Path Name="Arrow" 
                                                      Grid.Column="1" 
                                                      Fill="#A1A1AA" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#2D2D30" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#7C3AED" />
                                                <Setter TargetName="Arrow" Property="Fill" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#101010" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#7C3AED" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter Name="ContentSite"
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,28,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />

                            <Popup Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="true" 
                                   Focusable="false"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                      SnapsToDevicePixels="true"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder"
                                            Background="#1E1E1F"
                                            BorderBrush="#3F3F46"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,2,0,4">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.4"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="2,6,2,8" SnapsToDevicePixels="true">
                                        <StackPanel IsItemsHost="true" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Control Bar -->
        <Border Grid.Row="0" Background="#18181B" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="False">
                <Button x:Name="btnToggleSql" Content="📝 SQL Query Panel" Click="BtnToggleSql_Click" 
                        Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Padding="8,4" Margin="0,0,8,0" Cursor="Hand"/>
                
                <TextBlock Text="Chart:" VerticalAlignment="Center" Foreground="#A1A1AA" Margin="0,0,4,0"/>
                <ComboBox x:Name="comboChartType" Style="{StaticResource DarkComboBoxStyle}" Width="90" SelectedIndex="0" Margin="0,0,8,0">
                    <ComboBoxItem Content="bar"/>
                    <ComboBoxItem Content="line"/>
                    <ComboBoxItem Content="pie"/>
                </ComboBox>

                <Button x:Name="btnRunChart" Content="⚡ Run &amp; Chart" Click="BtnRunChart_Click" 
                        Background="#7C3AED" Foreground="White" BorderThickness="0" Padding="12,4" Cursor="Hand" FontWeight="SemiBold"/>

                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#10B981" FontSize="11" TextWrapping="Wrap" MaxWidth="300"/>
            </DockPanel>
        </Border>

        <!-- Collapsible SQL Input Panel -->
        <Border x:Name="sqlPanel" Grid.Row="1" Background="#09090B" BorderBrush="#27272A" BorderThickness="0,0,0,1" Padding="8" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Panel Header with Toggle Buttons & Connection Info -->
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
                    <TextBlock x:Name="txtConnectionInfo" Text="Connection: Retrieving..." Foreground="#38BDF8" FontSize="11" FontWeight="SemiBold" DockPanel.Dock="Right" VerticalAlignment="Center" TextAlignment="Right"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnSqlMode" Content="SQL Editor" Click="BtnSqlMode_Click" Width="90" Height="22" FontSize="11"
                                Background="#27272A" Foreground="#E4E4E7" BorderBrush="#7C3AED" BorderThickness="1" Cursor="Hand" Margin="0,0,4,0"/>
                        <Button x:Name="btnBuilderMode" Content="Quick Builder" Click="BtnBuilderMode_Click" Width="90" Height="22" FontSize="11"
                                Background="Transparent" Foreground="#A1A1AA" BorderBrush="Transparent" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                </DockPanel>

                <!-- SQL Editor View -->
                <Grid x:Name="panelSqlEditor" Grid.Row="1" Visibility="Visible" Height="130">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" MinWidth="100" x:Name="colSidebar"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Schema Explorer -->
                    <Border Grid.Column="0" Background="#141417" BorderBrush="#27272A" BorderThickness="1" CornerRadius="4" Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="True" Margin="2,2,2,4">
                                <Button x:Name="btnRefreshSidebar" Content="🔄" Click="BtnRefreshSidebar_Click" Width="20" Height="20" Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Cursor="Hand" DockPanel.Dock="Right" ToolTip="Refresh database schema"/>
                                <TextBlock Text="Schema Explorer" Foreground="#A1A1AA" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DockPanel>
                            <TreeView Grid.Row="1" x:Name="treeSchema" MouseDoubleClick="TreeSchema_MouseDoubleClick" Background="Transparent" BorderThickness="0" Foreground="#E4E4E7">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="#E4E4E7"/>
                                        <Setter Property="Padding" Value="1,2"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#27272A" ResizeBehavior="PreviousAndNext"/>

                    <!-- Monaco Editor WebView2 container -->
                    <Border Grid.Column="2" Background="#18181B" BorderBrush="#27272A" BorderThickness="1" CornerRadius="4">
                        <wv2:WebView2 x:Name="webViewMonaco" 
                                      HorizontalAlignment="Stretch" 
                                      VerticalAlignment="Stretch" 
                                      Visibility="Visible"/>
                    </Border>
                </Grid>

                <!-- Quick Builder View -->
                <Grid x:Name="panelQuickBuilder" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Table Selection -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,6">
                        <TextBlock Text="Table / View:" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <DockPanel>
                            <Button x:Name="btnRefreshSchema" Content="🔄" Click="BtnRefreshSchema_Click" Width="22" Height="22" Background="#27272A" Foreground="#E4E4E7" BorderBrush="#3F3F46" Cursor="Hand" DockPanel.Dock="Right" ToolTip="Refresh active database tables"/>
                            <ComboBox x:Name="comboTables" Style="{StaticResource DarkComboBoxStyle}" Height="22" SelectionChanged="ComboTables_SelectionChanged"/>
                        </DockPanel>
                    </StackPanel>

                    <!-- Aggregation -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,6,6">
                        <TextBlock Text="Aggregation:" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboAggregation" Style="{StaticResource DarkComboBoxStyle}" Height="22" SelectedIndex="0" SelectionChanged="ComboAggregation_SelectionChanged">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="SUM"/>
                            <ComboBoxItem Content="AVG"/>
                            <ComboBoxItem Content="COUNT"/>
                            <ComboBoxItem Content="MIN"/>
                            <ComboBoxItem Content="MAX"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- X-Axis Column -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,6,6">
                        <TextBlock Text="Category (X-Axis):" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboXAxis" Style="{StaticResource DarkComboBoxStyle}" Height="22"/>
                    </StackPanel>

                    <!-- Y-Axis Column -->
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,0,6">
                        <TextBlock Text="Value (Y-Axis):" Foreground="#A1A1AA" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="comboYAxis" Style="{StaticResource DarkComboBoxStyle}" Height="22"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" x:Name="txtBuilderInfo" Text="Select a table to begin mapping columns." Foreground="#71717A" FontSize="10" FontWeight="Normal" Margin="0,2,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Charting View -->
        <Grid Grid.Row="2">
            <wv2:WebView2 x:Name="webView" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Visibility="Collapsed" />
            
            <Grid x:Name="loadingPanel" Background="#121212">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="200" 
                                 Height="6" 
                                 Foreground="#A855F7" 
                                 Background="#1F2937" 
                                 BorderThickness="0" />
                    <TextBlock Text="Initializing QuerySight Canvas..." 
                               Foreground="#9CA3AF" 
                               FontSize="13" 
                               Margin="0,15,0,0" 
                               HorizontalAlignment="Center" 
                               FontFamily="Segoe UI, Arial" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
